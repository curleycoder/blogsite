@page
@model BlogSite.Pages_Categories.DeleteModel

@{
    ViewData["Title"] = "Delete Category";
}

<h1>Delete Category</h1>

<div class="alert alert-warning">Are you sure you want to delete this category?</div>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Category.Name</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Category.Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
</form>
