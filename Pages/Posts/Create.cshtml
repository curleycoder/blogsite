@page
@model BlogSite.Pages_Posts.CreateModel

@{
    ViewData["Title"] = "Create Post";
}

<section class="form-page-wrap">
    <div class="form-card">
        <div class="form-header">
            <div class="form-badge">New Post</div>
            <h1>Create a Blog Post</h1>
            <p class="form-subtext">
                Add a new post with a clear title and readable content.
            </p>
        </div>

        <form method="post" class="post-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-4">
                <label asp-for="Post.Title" class="form-label"></label>
                <input asp-for="Post.Title" class="form-control form-control-lg" placeholder="Enter post title" />
                <span asp-validation-for="Post.Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Post.Content" class="form-label"></label>
                <textarea asp-for="Post.Content" class="form-control form-textarea" rows="8"
                          placeholder="Write your post content here"></textarea>
                <span asp-validation-for="Post.Content" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <a asp-page="/Index">Back to Lists</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}