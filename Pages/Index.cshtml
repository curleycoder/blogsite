@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<h1 class="text-center mb-4">My Blog Posts</h1>

<div class="row">
    <div class="col-md-2">
        <a asp-page="/Posts/Create" class="btn btn-primary btn-sm mb-2 w-100">New Post</a>
        <a asp-page="/Authors/Create" class="btn btn-primary btn-sm mb-2 w-100">New Author</a>
        <a asp-page="/Categories/Create" class="btn btn-primary btn-sm mb-2 w-100">New Category</a>
    </div>

    <div class="col-md-7">
        @foreach (var post in Model.Posts)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h3 class="card-title">@post.Title</h3>
                    <p class="text-muted">
                        by @post.Author.Name in
                        <a asp-page="/Categories/Details" asp-route-id="@post.Category.Id">@post.Category.Name</a>
                    </p>
                    <p class="card-text">@post.Excerpt</p>
                    <a asp-page="/Posts/Details" asp-route-id="@post.Id">Read more</a>
                </div>
            </div>
        }
    </div>

    <div class="col-md-3">
        <h4>Categories</h4>
        <hr />
        @foreach (var category in Model.Categories)
        {
            <strong>@category.Name</strong>
            <ul>
                @foreach (var post in category.Posts)
                {
                    <li>
                        <a asp-page="/Posts/Details" asp-route-id="@post.Id">@post.Title</a>
                    </li>
                }
            </ul>
        }
    </div>
</div>
