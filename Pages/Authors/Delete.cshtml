@page
@model BlogSite.Pages_Authors.DeleteModel

@{
    ViewData["Title"] = "Delete Author";
}

<h1>Delete Author</h1>

<div class="alert alert-warning">Are you sure you want to delete this author?</div>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Author.Name</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Author.Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
</form>
