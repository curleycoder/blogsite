@page
@model BlogSite.Pages_Authors.IndexModel

@{
    ViewData["Title"] = "Authors";
}

<h1>Authors</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Add Author</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var author in Model.Authors)
        {
            <tr>
                <td>@author.Name</td>
                <td>
                    <a asp-page="./Details" asp-route-id="@author.Id">Details</a> |
                    <a asp-page="./Edit" asp-route-id="@author.Id">Edit</a> |
                    <a asp-page="./Delete" asp-route-id="@author.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
