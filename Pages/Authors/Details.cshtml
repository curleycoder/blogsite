@page
@model BlogSite.Pages_Authors.DetailsModel

@{
    ViewData["Title"] = Model.Author.Name;
}

<h1>@Model.Author.Name</h1>
<hr />

<h3>Posts by this author</h3>

@if (!Model.Author.Posts.Any())
{
    <p class="text-muted">No posts yet.</p>
}
else
{
    @foreach (var post in Model.Author.Posts)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@post.Title</h5>
                <p class="text-muted">@post.Category?.Name</p>
                <p class="card-text">@post.Excerpt</p>
                <a asp-page="/Posts/Details" asp-route-id="@post.Id">Read more</a>
            </div>
        </div>
    }
}

<div class="mt-3">
    <a asp-page="./Edit" asp-route-id="@Model.Author.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
